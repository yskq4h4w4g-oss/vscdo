{
  "name": "azure-devops-pr-manager",
  "displayName": "Azure DevOps PR Manager",
  "description": "Manage Azure DevOps pull requests and monitor pipeline status",
  "version": "1.3.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "azureDevOps.refreshPullRequests",
        "title": "Azure DevOps: Refresh Pull Requests",
        "icon": "$(refresh)"
      },
      {
        "command": "azureDevOps.createPullRequest",
        "title": "Azure DevOps: Create Pull Request",
        "icon": "$(git-pull-request-create)"
      },
      {
        "command": "azureDevOps.viewPullRequest",
        "title": "Azure DevOps: View Pull Request Details"
      },
      {
        "command": "azureDevOps.openPullRequestInBrowser",
        "title": "Azure DevOps: Open Pull Request in Browser",
        "icon": "$(link-external)"
      },
      {
        "command": "azureDevOps.configure",
        "title": "Azure DevOps: Configure Connection"
      },
      {
        "command": "azureDevOps.clearCredentials",
        "title": "Azure DevOps: Clear Stored Credentials"
      },
      {
        "command": "azureDevOps.approvePullRequest",
        "title": "Approve Pull Request",
        "icon": "$(check)"
      },
      {
        "command": "azureDevOps.rejectPullRequest",
        "title": "Reject Pull Request",
        "icon": "$(x)"
      },
      {
        "command": "azureDevOps.completePullRequest",
        "title": "Complete Pull Request",
        "icon": "$(check-all)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "azure-devops",
          "title": "Azure DevOps",
          "icon": "$(azure-devops)"
        }
      ]
    },
    "views": {
      "azure-devops": [
        {
          "id": "azureDevOpsPullRequests",
          "name": "Pull Requests"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "azureDevOps.refreshPullRequests",
          "when": "view == azureDevOpsPullRequests",
          "group": "navigation"
        },
        {
          "command": "azureDevOps.createPullRequest",
          "when": "view == azureDevOpsPullRequests",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "azureDevOps.viewPullRequest",
          "when": "view == azureDevOpsPullRequests && viewItem == pullRequest"
        },
        {
          "command": "azureDevOps.openPullRequestInBrowser",
          "when": "view == azureDevOpsPullRequests && viewItem == pullRequest"
        },
        {
          "command": "azureDevOps.approvePullRequest",
          "when": "view == azureDevOpsPullRequests && viewItem == pullRequest",
          "group": "inline"
        },
        {
          "command": "azureDevOps.rejectPullRequest",
          "when": "view == azureDevOpsPullRequests && viewItem == pullRequest",
          "group": "inline"
        },
        {
          "command": "azureDevOps.completePullRequest",
          "when": "view == azureDevOpsPullRequests && viewItem == pullRequest"
        }
      ]
    },
    "configuration": {
      "title": "Azure DevOps",
      "properties": {
        "azureDevOps.defaultMergeStrategy": {
          "type": "string",
          "default": "noFastForward",
          "enum": ["noFastForward", "squash", "rebase", "rebaseMerge"],
          "enumDescriptions": [
            "Merge (no fast-forward) - Create a merge commit",
            "Squash - Squash all commits into a single commit",
            "Rebase - Rebase and fast-forward",
            "Rebase and merge - Rebase and create a merge commit"
          ],
          "description": "Default merge strategy when completing pull requests"
        },
        "azureDevOps.defaultDeleteSourceBranch": {
          "type": "boolean",
          "default": false,
          "description": "Default setting for deleting source branch after merging"
        },
        "azureDevOps.prefillSourceBranch": {
          "type": "boolean",
          "default": false,
          "description": "Automatically prefill the current active git branch as the source branch when creating a pull request"
        },
        "azureDevOps.defaultTargetBranch": {
          "type": "string",
          "default": "",
          "description": "Default target branch to prefill when creating a pull request (e.g. 'main', 'develop')"
        },
        "azureDevOps.userEmail": {
          "type": "string",
          "default": "",
          "description": "Your email or Azure DevOps unique name used for filtering pull requests. Leave empty to auto-detect from your PAT."
        },
        "azureDevOps.filterMyPullRequests": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, only show pull requests you created or are listed as a reviewer on."
        },
        "azureDevOps.notifications.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show VS Code notifications when new comments or votes appear on pull requests you're involved in."
        },
        "azureDevOps.notifications.pollIntervalSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 15,
          "description": "How often (in seconds) to poll Azure DevOps for PR activity (comments and votes)."
        },
        "azureDevOps.redirectPrLinksToExtension": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, links to pull requests in the PR detail view open inside the extension instead of in the browser."
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yskq4h4w4g-oss/vscdo.git"
  },
  "publisher": "tobiaswadsethdev",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.x",
    "@typescript-eslint/parser": "^6.x",
    "eslint": "^8.x",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "azure-devops-node-api": "^15.1.2"
  }
}
